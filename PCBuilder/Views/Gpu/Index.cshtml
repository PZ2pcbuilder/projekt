@model IEnumerable<PCBuilder.Models.Gpu>

@{
    ViewData["Title"] = "Karty Graficzne";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5"><i class="bi bi-gpu-card"></i> Lista Kart Graficznych</h1>
        <span class="badge bg-secondary">Liczba pozycji: @Model.Count()</span>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control" placeholder="Szukaj po nazwie lub chipsecie..." value="@ViewData["CurrentFilter"]" />
                        <button type="submit" class="btn btn-primary">Filtruj</button>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Model</th>
                    <th>Chipset</th>
                    <th>Pamięć VRAM</th>
                    <th class="text-center">Taktowanie (Boost)</th>
                    <th class="text-center">Długość</th>
                    <th class="text-end">Cena</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                            <small class="text-muted">@item.Color</small>
                        </td>
                        <td>
                            <span class="badge bg-info text-dark">@item.Chipset</span>
                        </td>
                        <td>@(item.Memory) GB</td>
                        <td class="text-center">
                            <span class="text-muted">@item.CoreClock MHz</span>
                            <i class="bi bi-arrow-right mx-1"></i>
                            <span class="fw-bold text-danger">@item.BoostClock MHz</span>
                        </td>
                        <td class="text-center">@(item.Length) mm</td>
                        <td class="text-end fw-bold text-success">
                            @(item.Price?.ToString("C2") ?? "Zapytaj o cenę")
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary" title="Dodaj do konfiguracji">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning mt-4 text-center">
        </div>
    }
</div>

<style>
    .table thead th {
        font-weight: 500;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
    }
    .badge {
        font-weight: 500;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }
</style>