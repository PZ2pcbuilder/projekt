@{
    ViewData["Title"] = "Twój Zestaw Komputerowy";
    
    // Rzutowanie danych przesłanych przez kontroler z ViewBag na konkretne modele
    var cpu = ViewBag.SelectedCpu as PCBuilder.Models.Cpu;
    var gpu = ViewBag.SelectedGpu as PCBuilder.Models.Gpu;
    var motherboard = ViewBag.SelectedMotherboard as PCBuilder.Models.Motherboard;
    var memory = ViewBag.SelectedMemory as PCBuilder.Models.Memory;
    var pcCase = ViewBag.SelectedCase as PCBuilder.Models.Case;
    var cooler = ViewBag.SelectedCpuCooler as PCBuilder.Models.CpuCooler;
    var storage = ViewBag.SelectedStorage as PCBuilder.Models.Storage;
    var powerSupply = ViewBag.SelectedPowerSupply as PCBuilder.Models.PowerSupply; // DODANE: Model zasilacza

    // Kalkulacja łącznej ceny w locie
    decimal totalCena = 0;
    totalCena += cpu?.Price ?? 0;
    totalCena += gpu?.Price ?? 0;
    totalCena += motherboard?.Price ?? 0;
    totalCena += memory?.Price ?? 0;
    totalCena += pcCase?.Price ?? 0;
    totalCena += cooler?.Price ?? 0;
    totalCena += storage?.Price ?? 0;
    totalCena += powerSupply?.Price ?? 0;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5"><i class="bi bi-pc"></i> Twój Wirtualny PC</h1>
        @if (totalCena > 0)
        {
            <h3 class="text-success mb-0 fw-bold">Razem: @totalCena.ToString("C")</h3>
        }
    </div>

    <div class="row">
        <div class="col-md-9">
            <div class="list-group shadow-sm">
                
                <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-cpu"></i></div>
                        <div>
                            <h5 class="mb-1">Procesor (CPU)</h5>
                            @if (cpu != null)
                            {
                                <span class="fw-bold text-primary">@cpu.Name</span>
                                <span class="badge bg-light text-dark border ms-2">@cpu.Socket</span>
                                <div class="text-success small fw-bold">@cpu.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano procesora</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (cpu != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="Cpu" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="Cpu" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-snow"></i></div>
                        <div>
                            <h5 class="mb-1">Chłodzenie procesora</h5>
                            @if (cooler != null)
                            {
                                <span class="fw-bold text-primary">@cooler.Name</span>
                                <span class="badge bg-light text-dark border ms-2">@cooler.HeightMm mm</span>
                                <div class="text-success small fw-bold">@cooler.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano chłodzenia procesora</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (cooler != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="CpuCooler" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="CpuCooler" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-motherboard"></i></div>
                        <div>
                            <h5 class="mb-1">Płyta Główna</h5>
                            @if (motherboard != null)
                            {
                                <span class="fw-bold text-primary">@motherboard.Name</span>
                                <span class="badge bg-light text-dark border ms-2">@motherboard.Socket</span>
                                <span class="badge bg-secondary ms-1">@motherboard.MemoryType</span>
                                <div class="text-success small fw-bold">@motherboard.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano płyty głównej</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (motherboard != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="Motherboard" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="Motherboard" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-memory"></i></div>
                        <div>
                            <h5 class="mb-1">Pamięć RAM</h5>
                            @if (memory != null)
                            {
                                <span class="fw-bold text-primary">@memory.Name</span>
                                <span class="badge bg-info text-dark ms-2">@memory.MemoryType</span>
                                <span class="badge bg-dark ms-1">@memory.Capacity GB (@memory.Modules x)</span>
                                <div class="text-success small fw-bold">@memory.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano pamięci RAM</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (memory != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="Memory" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="Memory" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-hdd-rack"></i></div>
                        <div>
                            <h5 class="mb-1">Pamięć masowa (Dysk)</h5>
                            @if (storage != null)
                            {
                                <span class="fw-bold text-primary">@storage.Name</span>
                                <span class="badge bg-light text-dark border ms-2">@storage.Type (@storage.Interface)</span>
                                <span class="badge bg-dark ms-1">@storage.Capacity</span>
                                <div class="text-success small fw-bold">@storage.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano dysku twardego</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (storage != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="Storage" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="Storage" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-gpu-card"></i></div>
                        <div>
                            <h5 class="mb-1">Karta Graficzna (GPU)</h5>
                            @if (gpu != null)
                            {
                                <span class="fw-bold text-primary">@gpu.Name</span>
                                <span class="badge bg-light text-dark border ms-2">@gpu.Length mm</span>
                                <div class="text-success small fw-bold">@gpu.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano karty graficznej</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (gpu != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="Gpu" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="Gpu" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-plug"></i></div>
                        <div>
                            <h5 class="mb-1">Zasilacz (PSU)</h5>
                            @if (powerSupply != null)
                            {
                                <span class="fw-bold text-primary">@powerSupply.Name</span>
                                <span class="badge bg-dark text-warning ms-2">@powerSupply.Wattage W</span>
                                <span class="badge bg-light text-dark border ms-1">@powerSupply.Efficiency</span>
                                <div class="text-success small fw-bold">@powerSupply.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano zasilacza</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (powerSupply != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="PowerSupply" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="PowerSupply" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

                <div class="list-group-item d-flex justify-content-between align-items-center p-3 mt-2">
                    <div class="d-flex align-items-center">
                        <div class="fs-3 text-secondary me-3"><i class="bi bi-pc-display"></i></div>
                        <div>
                            <h5 class="mb-1">Obudowa</h5>
                            @if (pcCase != null)
                            {
                                <span class="fw-bold text-primary">@pcCase.Name</span>
                                <span class="badge bg-light text-dark border ms-2">Max GPU: @(pcCase.MaxGpuLengthMm)mm</span>
                                <div class="text-success small fw-bold">@pcCase.Price?.ToString("C")</div>
                            }
                            else
                            {
                                <span class="text-muted small">Nie wybrano obudowy</span>
                            }
                        </div>
                    </div>
                    <div>
                        @if (pcCase != null)
                        {
                            <a asp-action="RemoveComponent" asp-route-type="Case" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
                        }
                        else
                        {
                            <a asp-controller="Case" asp-action="Index" class="btn btn-sm btn-primary">Wybierz</a>
                        }
                    </div>
                </div>

            </div>

            @if (cpu != null || gpu != null || motherboard != null || memory != null || pcCase != null || cooler != null || storage != null || powerSupply != null)
            {
                <a asp-action="Clear" class="btn btn-outline-danger mt-4 btn-sm"><i class="bi bi-arrow-counterclockwise"></i> Wyczyść cały zestaw</a>
            }
        </div>
    </div>
</div>