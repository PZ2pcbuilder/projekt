@{
    ViewData["Title"] = "Strona Główna";
}

<div class="container mt-5">
    <div class="text-center py-5 mb-5 bg-light rounded-3 border shadow-sm px-4">
        <h1 class="display-4 fw-bold text-dark mb-3">
            <i class="bi bi-pc-display-horizontal text-primary me-2"></i>Witaj w PCBuilder
        </h1>
        <p class="lead text-secondary mx-auto" style="max-width: 700px;">
            Zaprojektuj swój wymarzony zestaw komputerowy. Nasz konfigurator pomoże Ci dobrać kompatybilne podzespoły, sprawdzając parametry techniczne w czasie rzeczywistym.
        </p>
        <div class="mt-4">
            <a href="@Url.Action("Index", "Configuration")" class="btn btn-primary btn-lg px-4 me-2 shadow-sm">
                Rozpocznij składanie
            </a>
            <a href="@Url.Action("Index", "Cpu")" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">
                Przeglądaj części
            </a>
        </div>
    </div>
</div>

<style>
    .letter-spacing {
        letter-spacing: 0.06em;
    }

    .custom-card {
        transition: background-color 0.2s ease, border-color 0.2s ease;
        background-color: #ffffff;
    }

    .custom-card:hover {
        background-color: rgba(13, 110, 253, 0.02) !important;
        border-color: #93c5fd !important;
    }

    .icon-box {
        width: 56px;
        height: 56px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }

    .bg-primary-subtle {
        background-color: #e0f2fe !important;
    }

    .bg-info-subtle {
        background-color: #e0f2fe !important;
    }

    .text-info-emphasis {
        color: #0369a1 !important;
    }

    .bg-warning-subtle {
        background-color: #fffbeb !important;
    }

    .text-warning-emphasis {
        color: #b45309 !important;
    }

    .bg-secondary-subtle {
        background-color: #f1f5f9 !important;
    }
</style>
