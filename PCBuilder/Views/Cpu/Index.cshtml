@model PCBuilder.Models.Filters.CpuIndexViewModel

@{
    ViewData["Title"] = "Procesory";
    var f = Model.Filter;
}
@if (ViewData["CompatibilityMessage"] != null)
{
    <div class="alert alert-info shadow-sm mb-4">
        <i class="bi bi-info-circle-fill me-2"></i> @ViewData["CompatibilityMessage"]
    </div>
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-dark"><i class="bi bi-cpu text-primary"></i> Lista Procesorów</h1>
        <span class="badge bg-dark px-3 py-2 fs-6 shadow-sm">Liczba pozycji: @Model.Items.Count</span>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h6 class="fw-bold mb-0"><i class="bi bi-funnel me-2 text-primary"></i>Filtry</h6>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Wyczyść filtry</a>
        </div>
        <div class="card-body py-3">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-12">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="Search" class="form-control" placeholder="Szukaj po nazwie, gnieździe, architekturze..." value="@f.Search" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label class="form-label small text-muted fw-semibold">Cena (PLN)</label>
                    <div class="input-group">
                        <input type="number" step="0.01" name="MinPrice" class="form-control" placeholder="od" value="@f.MinPrice" />
                        <input type="number" step="0.01" name="MaxPrice" class="form-control" placeholder="do" value="@f.MaxPrice" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted fw-semibold">Liczba rdzeni</label>
                    <div class="input-group">
                        <input type="number" name="MinCores" class="form-control" placeholder="od" value="@f.MinCores" />
                        <input type="number" name="MaxCores" class="form-control" placeholder="do" value="@f.MaxCores" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted fw-semibold">TDP (W)</label>
                    <div class="input-group">
                        <input type="number" name="MinTdp" class="form-control" placeholder="od" value="@f.MinTdp" />
                        <input type="number" name="MaxTdp" class="form-control" placeholder="do" value="@f.MaxTdp" />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted fw-semibold">Socket</label>
                    <select name="Socket" class="form-select">
                        <option value="">Dowolny</option>
                        @foreach (var s in Model.Sockets)
                        {
                            <option value="@s" selected="@(f.Socket == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-muted fw-semibold">Typ pamięci</label>
                    <select name="MemoryType" class="form-select">
                        <option value="">Dowolny</option>
                        @foreach (var s in Model.MemoryTypes)
                        {
                            <option value="@s" selected="@(f.MemoryType == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small text-muted fw-semibold">Architektura</label>
                    <select name="Microarchitecture" class="form-select">
                        <option value="">Dowolna</option>
                        @foreach (var s in Model.Microarchitectures)
                        {
                            <option value="@s" selected="@(f.Microarchitecture == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-5 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary px-4 me-2"><i class="bi bi-funnel-fill me-1"></i>Filtruj</button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow rounded-3 border">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4 py-3" style="width: 25%;">Nazwa procesora</th>
                    <th class="text-center py-3" style="width: 10%;">Rdzenie</th>
                    <th class="text-center py-3" style="width: 18%;">Taktowanie</th>
                    <th class="text-center py-3" style="width: 12%;">Socket</th>
                    <th class="text-center py-3" style="width: 12%;">Typ pamięci</th>
                    <th class="text-center py-3" style="width: 10%;">TDP</th>
                    <th class="text-end py-3 pe-4" style="width: 13%;">Cena</th>
                    <th style="width: 5%;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr class="custom-row">
                        <td class="ps-4 py-3">
                            <div class="fw-bold text-dark fs-6">@item.Name</div>
                            <small class="text-muted">@item.Microarchitecture</small>
                        </td>
                        <td class="text-center py-3">
                            <span class="badge bg-secondary-subtle text-secondary-emphasis fw-bold px-3 py-2 rounded">@item.CoreCount</span>
                        </td>
                        <td class="text-center py-3">
                            <div class="d-flex flex-column align-items-center justify-content-center">
                                <span class="fw-bold text-dark font-monospace">@item.CoreClock.Trim()</span>
                                <span class="badge bg-warning-subtle text-warning-emphasis rounded-pill mt-1 px-2 py-1 small">
                                    <i class="bi bi-lightning-charge-fill"></i> BOOST @item.BoostClock.Trim()
                                </span>
                            </div>
                        </td>
                        <td class="text-center py-3">
                            <span class="badge bg-light text-dark border px-3 py-1 font-monospace">@item.Socket</span>
                        </td>
                        <td class="text-center py-3">
                            <span class="badge bg-info-subtle text-info-emphasis fw-bold px-3 py-2 rounded-pill">@item.MemoryType</span>
                        </td>
                        <td class="text-center py-3 text-secondary fw-bold">@(item.Tdp)W</td>
                        <td class="text-end fw-bold text-success py-3 pe-4">@(item.Price?.ToString("C") ?? "N/A")</td>
                        <td class="text-end pe-4 py-3">
                            <form asp-controller="Configuration" asp-action="AddComponent" method="post" class="m-0">
                                <input type="hidden" name="type" value="Cpu" />
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Dodaj do konfiguracji">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="alert alert-warning mt-4 text-center shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> Brak procesorów spełniających wybrane filtry.
        </div>
    }
</div>

<style>
    .table thead th { font-weight: 600; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.06em; border: none; }
    .custom-row { transition: background-color 0.2s ease; }
    .table-hover tbody tr.custom-row:hover { background-color: rgba(13, 110, 253, 0.04) !important; }
    .bg-info-subtle { background-color: #e0f2fe !important; }
    .text-info-emphasis { color: #0369a1 !important; }
    .bg-secondary-subtle { background-color: #f1f5f9 !important; }
    .text-secondary-emphasis { color: #334155 !important; }
    .bg-warning-subtle { background-color: #fffbeb !important; }
    .text-warning-emphasis { color: #b45309 !important; }
</style>
