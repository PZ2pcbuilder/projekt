@model IEnumerable<PCBuilder.Models.Motherboard>

@{
    ViewData["Title"] = "Płyty Główne";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5"><i class="bi bi-motherboard"></i> Płyty Główne</h1>
        <span class="badge bg-secondary">Liczba pozycji: @Model.Count()</span>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control" placeholder="Szukaj po nazwie, sockecie (np. AM5) lub formacie..." value="@ViewData["CurrentFilter"]" />
                        <button type="submit" class="btn btn-primary">Filtruj</button>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Model</th>
                    <th class="text-center">Socket</th>
                    <th class="text-center">Format</th>
                    <th class="text-center">RAM</th>
                    <th class="text-center">Sloty M.2</th>
                    <th class="text-end">Cena</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                            <small class="text-muted">Chipset: @(item.Name.Split(' ')[0])</small>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary">@item.Socket</span>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border">@item.FormFactor</span>
                        </td>
                        <td class="text-center">
                            <div class="small">
                                <strong>@item.MemoryType</strong><br />
                                <span class="text-muted">@item.MemorySlots sloty (Max @(item.MaxMemory)GB)</span>
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-info text-dark">@item.M2Slots x M.2</span>
                        </td>
                        <td class="text-end fw-bold text-success">
                            @(item.Price?.ToString("C") ?? "N/A")
                        </td>
                        <td class="text-end">
                            <form asp-controller="Configuration" asp-action="AddComponent" method="post">
                                <input type="hidden" name="type" value="Motherboard" />
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Dodaj do konfiguracji">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning mt-4 text-center">
            Nie znaleziono płyt głównych spełniających kryteria.
        </div>
    }
</div>

<style>
    .table thead th {
        font-weight: 500;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.05em;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }
</style>