@model IEnumerable<PCBuilder.Models.CpuCooler>

@{
    ViewData["Title"] = "Chłodzenie procesora";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5"><i class="bi bi-snow"></i> Chłodzenie procesora</h1>
        <span class="badge bg-secondary">Liczba pozycji: @Model.Count()</span>
    </div>

    @if (ViewData["CompatibilityMessage"] != null)
    {
        <div class="alert alert-info shadow-sm mb-4">
            <i class="bi bi-info-circle-fill me-2"></i> @ViewData["CompatibilityMessage"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control" placeholder="Szukaj po nazwie lub gnieździe (np. AM5, LGA1700)..." value="@ViewData["CurrentFilter"]" />
                        <button type="submit" class="btn btn-primary">Filtruj</button>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Model i Kolor</th>
                    <th class="text-center">Wysokość</th>
                    <th class="text-center">Prędkość (RPM)</th>
                    <th class="text-center">Głośność</th>
                    <th>Obsługiwane gniazda (Sockets)</th>
                    <th class="text-end">Cena</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                            <small class="text-muted">Kolor: @(string.IsNullOrEmpty(item.Color) ? "Standard" : item.Color)</small>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border fw-bold">@item.HeightMm mm</span>
                        </td>
                        <td class="text-center text-muted small">
                            @(item.Rpm)
                        </td>
                        <td class="text-center small">
                            @(item.NoiseLevel) dBa
                        </td>
                        <td>
                            <span class="text-wrap small text-secondary">@item.SupportedSockets</span>
                        </td>
                        <td class="text-end fw-bold text-success">
                            @(item.Price?.ToString("C") ?? "N/A")
                        </td>
                        <td class="text-end">
                            <form asp-controller="Configuration" asp-action="AddComponent" method="post">
                                <input type="hidden" name="type" value="CpuCooler" />
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Dodaj do konfiguracji">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>