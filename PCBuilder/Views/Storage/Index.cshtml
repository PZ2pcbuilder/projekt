@model IEnumerable<PCBuilder.Models.Storage>

@{
    ViewData["Title"] = "Pamięć masowa (Dyski)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5"><i class="bi bi-hdd-rack"></i> Pamięć masowa (Dyski)</h1>
        <span class="badge bg-secondary">Dostępnych: @Model.Count()</span>
    </div>

    @if (ViewData["CompatibilityMessage"] != null)
    {
        <div class="alert alert-info shadow-sm mb-4">
            <i class="bi bi-info-circle-fill me-2"></i> @ViewData["CompatibilityMessage"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchString" class="form-control" placeholder="Szukaj po nazwie, typie (SSD/HDD) lub interfejsie (NVMe/SATA)..." value="@ViewData["CurrentFilter"]" />
                        <button type="submit" class="btn btn-primary">Filtruj</button>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść filtry</a>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Model / Nazwa</th>
                    <th class="text-center">Typ</th>
                    <th class="text-center">Pojemność</th>
                    <th class="text-center">Interfejs</th>
                    <th class="text-center">Format fizyczny</th>
                    <th class="text-end">Cena</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.Name</div>
                        </td>
                        <td class="text-center">
                            <span class="badge @(item.Type == "SSD" ? "bg-success" : "bg-warning text-dark")">@item.Type</span>
                        </td>
                        <td class="text-center fw-bold">
                            @item.Capacity
                        </td>
                        <td class="text-center text-muted small">
                            @item.Interface
                        </td>
                        <td class="text-center small">
                            @item.FormFactor
                        </td>
                        <td class="text-end fw-bold text-success">
                            @(item.Price?.ToString("C") ?? "N/A")
                        </td>
                        <td class="text-end">
                            <form asp-controller="Configuration" asp-action="AddComponent" method="post">
                                <input type="hidden" name="type" value="Storage" />
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-primary" title="Dodaj ten dysk do komputera">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .table th {
        font-weight: 500;
        text-transform: uppercase;
        font-size: 0.82rem;
        letter-spacing: 0.05em;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(40, 167, 69, 0.04);
    }
</style>