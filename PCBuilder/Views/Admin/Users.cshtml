@{
    ViewData["Title"] = "Zarządzanie Użytkownikami";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-dark"><i class="bi bi-people text-primary"></i> Użytkownicy</h1>
        <button class="btn btn-primary shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#addUserModal">
            <i class="bi bi-person-plus me-2"></i>Dodaj użytkownika
        </button>
    </div>

    <div id="adminAlert" class="alert d-none"></div>

    <div class="table-responsive shadow rounded-3 border bg-white">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4 py-3" style="width: 8%;">ID</th>
                    <th class="py-3">Użytkownik</th>
                    <th class="py-3" style="width: 18%;">Rola</th>
                    <th class="text-end pe-4 py-3" style="width: 35%;">Akcje</th>
                </tr>
            </thead>
            <tbody id="usersTbody"></tbody>
        </table>
    </div>
</div>

<!-- Modal: Dodaj użytkownika -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Nowy użytkownik</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="newUserError" class="alert alert-danger d-none"></div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Nazwa użytkownika</label>
                    <input id="newUsername" type="text" class="form-control" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Hasło (min. 4 znaki)</label>
                    <input id="newPassword" type="password" class="form-control" autocomplete="new-password">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Anuluj</button>
                <button id="addUserBtn" type="button" class="btn btn-primary">Utwórz</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Zmiana hasła -->
<div class="modal fade" id="passwordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-key me-2"></i>Zmień hasło</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="pwdError" class="alert alert-danger d-none"></div>
                <p class="text-muted small">Użytkownik: <strong id="pwdUserName"></strong></p>
                <input id="pwdNew" type="password" class="form-control" placeholder="Nowe hasło (min. 4 znaki)" autocomplete="new-password">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Anuluj</button>
                <button id="pwdSaveBtn" type="button" class="btn btn-primary">Zapisz</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const tbody = document.getElementById('usersTbody');
    const alertBox = document.getElementById('adminAlert');
    let pwdTargetUserId = null;

    function showAlert(msg, type = 'danger') {
        alertBox.className = `alert alert-${type}`;
        alertBox.textContent = msg;
        setTimeout(() => alertBox.classList.add('d-none'), 4000);
    }

    async function loadUsers() {
        const resp = await fetch('/api/auth/users', { credentials: 'same-origin' });
        if (!resp.ok) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-5">Błąd ładowania.</td></tr>';
            return;
        }
        const users = await resp.json();
        if (users.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-5">Brak użytkowników.</td></tr>';
            return;
        }
        tbody.innerHTML = users.map(u => {
            const isAdminUser = u.username === 'admin';
            const roleBadge = u.role === 'Admin'
                ? '<span class="badge bg-primary">Admin</span>'
                : '<span class="badge bg-secondary">User</span>';
            return `
                <tr>
                    <td class="ps-4">${u.id}</td>
                    <td><strong>${u.username}</strong></td>
                    <td>${roleBadge}</td>
                    <td class="text-end pe-4">
                        <button class="btn btn-sm btn-outline-secondary me-1" onclick="changePassword(${u.id}, '${u.username}')">
                            <i class="bi bi-key"></i> Hasło
                        </button>
                        ${isAdminUser ? '' : `
                          <button class="btn btn-sm btn-outline-info me-1" onclick="toggleRole(${u.id}, '${u.role}')">
                            <i class="bi bi-arrow-repeat"></i> ${u.role === 'Admin' ? 'Na User' : 'Na Admin'}
                          </button>
                          <button class="btn btn-sm btn-outline-danger" onclick="deleteUser(${u.id}, '${u.username}')">
                            <i class="bi bi-trash"></i> Usuń
                          </button>`}
                    </td>
                </tr>`;
        }).join('');
    }

    async function deleteUser(id, name) {
        if (!confirm(`Usunąć użytkownika "${name}"?`)) return;
        const resp = await fetch(`/api/auth/users/${id}`, { method: 'DELETE', credentials: 'same-origin' });
        if (!resp.ok) {
            const data = await resp.json().catch(() => ({}));
            showAlert(data.error || 'Błąd usuwania.');
            return;
        }
        showAlert('Użytkownik usunięty.', 'success');
        loadUsers();
    }

    async function toggleRole(id, currentRole) {
        const newRole = currentRole === 'Admin' ? 'User' : 'Admin';
        const resp = await fetch(`/api/auth/users/${id}/role`, {
            method: 'PUT',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ role: newRole })
        });
        if (!resp.ok) {
            const data = await resp.json().catch(() => ({}));
            showAlert(data.error || 'Błąd zmiany roli.');
            return;
        }
        showAlert('Rola zmieniona.', 'success');
        loadUsers();
    }

    function changePassword(id, name) {
        pwdTargetUserId = id;
        document.getElementById('pwdUserName').textContent = name;
        document.getElementById('pwdNew').value = '';
        document.getElementById('pwdError').classList.add('d-none');
        new bootstrap.Modal(document.getElementById('passwordModal')).show();
    }

    document.getElementById('pwdSaveBtn').addEventListener('click', async () => {
        const newPwd = document.getElementById('pwdNew').value;
        const errBox = document.getElementById('pwdError');
        if (!newPwd || newPwd.length < 4) {
            errBox.textContent = 'Hasło musi mieć min. 4 znaki.';
            errBox.classList.remove('d-none');
            return;
        }
        const resp = await fetch(`/api/auth/users/${pwdTargetUserId}/password`, {
            method: 'PUT',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ newPassword: newPwd })
        });
        if (!resp.ok) {
            const data = await resp.json().catch(() => ({}));
            errBox.textContent = data.error || 'Błąd zmiany hasła.';
            errBox.classList.remove('d-none');
            return;
        }
        bootstrap.Modal.getInstance(document.getElementById('passwordModal')).hide();
        showAlert('Hasło zmienione.', 'success');
    });

    document.getElementById('addUserBtn').addEventListener('click', async () => {
        const username = document.getElementById('newUsername').value.trim();
        const password = document.getElementById('newPassword').value;
        const errBox = document.getElementById('newUserError');
        errBox.classList.add('d-none');

        if (!username || !password) {
            errBox.textContent = 'Uzupełnij login i hasło.';
            errBox.classList.remove('d-none');
            return;
        }
        const resp = await fetch('/api/auth/users', {
            method: 'POST',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password })
        });
        if (!resp.ok) {
            const data = await resp.json().catch(() => ({}));
            errBox.textContent = data.error || 'Błąd dodawania.';
            errBox.classList.remove('d-none');
            return;
        }
        bootstrap.Modal.getInstance(document.getElementById('addUserModal')).hide();
        document.getElementById('newUsername').value = '';
        document.getElementById('newPassword').value = '';
        showAlert('Utworzono użytkownika.', 'success');
        loadUsers();
    });

    loadUsers();
</script>
}
